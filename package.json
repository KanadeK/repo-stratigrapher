{
  "name": "repo-stratigrapher",
  "version": "0.1.0",
  "description": "Layer Git history, directory evolution, test failures, and file hotspots into an interactive code stratigraphy map for repository onboarding.",
  "type": "module",
  "license": "MIT",
  "author": "KanadeK <121669563+KanadeK@users.noreply.github.com>",
  "homepage": "https://kanadek.github.io/repo-stratigrapher/",
  "repository": {
    "type": "git",
    "url": "https://github.com/KanadeK/repo-stratigrapher.git"
  },
  "bugs": {
    "url": "https://github.com/KanadeK/repo-stratigrapher/issues"
  },
  "bin": {
    "repo-stratigrapher": "./bin/repo-stratigrapher.mjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --check .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "fixture": "node scripts/generate_fixture_repo.mjs examples/fixture-repo",
    "demo": "npm run fixture && node bin/repo-stratigrapher.mjs analyze --repo examples/fixture-repo --out dist-demo",
    "package": "npm run build && node scripts/package_release.mjs",
    "verify": "node scripts/verify.mjs",
    "release-check": "node scripts/release_check.mjs"
  },
  "dependencies": {
    "@phosphor-icons/react": "2.1.10",
    "d3": "7.9.0",
    "simple-git": "3.36.0",
    "sql.js": "1.13.0",
    "tsx": "4.20.3"
  },
  "devDependencies": {
    "@eslint/js": "9.32.0",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.6.4",
    "@testing-library/react": "16.3.0",
    "@types/d3": "7.4.3",
    "@types/node": "24.1.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "3.2.7",
    "eslint": "9.32.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "jsdom": "26.1.0",
    "prettier": "3.6.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.38.0",
    "vite": "7.3.6",
    "vitest": "3.2.7",
    "wait-on": "8.0.4"
  },
  "engines": {
    "node": ">=22.12"
  }
}
